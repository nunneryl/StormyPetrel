# Required — Supabase connection. Server components use the service key,
# so it MUST stay server-only (no NEXT_PUBLIC_ prefix). Never commit a
# real key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional — public-facing canonical URL. Used to build absolute URLs in
# robots.txt, sitemap.xml, OpenGraph metadata, and canonical links.
# Defaults to https://stormypetrel.surf when unset.
NEXT_PUBLIC_SITE_URL=https://stormypetrel.surf
